#!/usr/bin/env bash
#
# kubectl-ekslogs - Collect EKS node diagnostic log bundles
#
# This plugin uses the EKS NodeDiagnostic API to capture and download
# support log bundles from one or more EKS cluster nodes.

set -euo pipefail

readonly DEFAULT_TIMEOUT="300s"

# --- Colors & Formatting ---

if [[ -t 1 ]]; then
    readonly RED='\033[0;31m'
    readonly GREEN='\033[0;32m'
    readonly YELLOW='\033[1;33m'
    readonly CYAN='\033[0;36m'
    readonly RESET='\033[0m'
else
    readonly RED='' GREEN='' YELLOW='' CYAN='' RESET=''
fi

# --- Helpers ---

info()    { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*" >&2; }
error()   { echo -e "${RED}✖${RESET} $*" >&2; }
status()  { echo -e "${CYAN}⟳${RESET} $*"; }

usage() {
    cat <<EOF
kubectl ekslogs — Collect EKS node diagnostic log bundles

USAGE
    kubectl ekslogs [FLAGS] <node> [node...]
    kubectl ekslogs [FLAGS] -l <label-selector>

FLAGS
    -l, --selector <selector>  Select nodes by label (same syntax as kubectl -l)
    -t, --timeout <duration>   Timeout for log collection (default: ${DEFAULT_TIMEOUT})
    -o, --output-dir <path>    Directory to save log bundles (default: current directory)
        --s3 <bucket-name>     Upload logs to S3 bucket and download from there
        --key <s3-key-prefix>  S3 key prefix for logs (default: root of bucket)
        --no-proxy             Use a debug pod and kubectl cp instead of the node proxy API
        --debug-image <image>  Container image for debug pod
    -h, --help                 Show this help message

EXAMPLES
    # Collect logs from a single node
    kubectl ekslogs ip-10-0-1-42.ec2.internal

    # Collect logs from all nodes in a node group
    kubectl ekslogs -l eks.amazonaws.com/nodegroup=my-node-group

    # Upload logs to S3 bucket root
    kubectl ekslogs --s3 my-bucket ip-10-0-1-42.ec2.internal

    # Upload logs to S3 with custom key prefix
    kubectl ekslogs --s3 my-bucket --key logs/2024-03 ip-10-0-1-42.ec2.internal

    # Use debug pod transfer (no node proxy API required)
    kubectl ekslogs --no-proxy --debug-image public.ecr.aws/docker/library/busybox:stable-musl ip-10-0-1-42.ec2.internal

    # Collect logs with a custom timeout and output directory
    kubectl ekslogs --timeout 600s --output-dir /tmp/logs ip-10-0-1-42.ec2.internal

PREREQUISITES
    - kubectl configured with access to an EKS cluster
    - The EKS Node Monitoring Agent Daemonset must be installed within the cluster
    - When using --no-proxy: permissions to create pods with hostPath volumes
    - When using --s3: AWS credentials configured and boto3 installed (pip install boto3)
EOF
}

# Convert node name to a valid pod name (lowercase, no dots, max 63 chars)
sanitize_pod_name() {
    local node="$1"
    echo "ekslogs-${node}" | tr '.' '-' | tr '[:upper:]' '[:lower:]' | cut -c1-63 | sed 's/-$//'
}

cleanup() {
    local exit_code=$?

    if [[ ${#TRANSFER_PODS[@]} -gt 0 ]]; then
        warn "Cleaning up transfer pods..."
        for pod in "${TRANSFER_PODS[@]}"; do
            kubectl delete pod "$pod" --ignore-not-found >/dev/null 2>&1 || true
        done
    fi

    if [[ ${#NODE_NAMES[@]} -gt 0 ]]; then
        warn "Cleaning up NodeDiagnostic resources..."
        for node in "${NODE_NAMES[@]}"; do
            kubectl delete nodediagnostic "$node" --ignore-not-found >/dev/null 2>&1 || true
        done
    fi

    exit "$exit_code"
}

resolve_selector() {
    local selector="$1"
    local nodes

    nodes=$(kubectl get nodes -l "$selector" -o jsonpath='{.items[*].metadata.name}' 2>/dev/null)

    if [[ -z "$nodes" ]]; then
        error "No nodes found matching selector: ${selector}"
        exit 1
    fi

    read -ra RESOLVED_NODES <<< "$nodes"
    info "Selector matched ${#RESOLVED_NODES[@]} node(s): ${RESOLVED_NODES[*]}"
}

download_via_proxy() {
    local node="$1"
    local output_path="$2"

    if ! kubectl get --raw "/api/v1/nodes/${node}/proxy/logs/support/${node}-logs.tar.gz" > "$output_path"; then
        error "Failed to download log bundle for node: ${node}"
        return 1
    fi
}

download_via_debug_pod() {
    local node="$1"
    local output_path="$2"
    local pod_name

    pod_name=$(sanitize_pod_name "$node")
    TRANSFER_PODS+=("$pod_name")

    status "Creating transfer pod ${pod_name} on node ${node}..."

    cat <<EOF | kubectl apply -f - >/dev/null 2>&1
apiVersion: v1
kind: Pod
metadata:
  name: ${pod_name}
  labels:
    app.kubernetes.io/managed-by: kubectl-ekslogs
    app.kubernetes.io/component: log-transfer
spec:
  nodeName: ${node}
  restartPolicy: Never
  tolerations:
    - operator: Exists
  containers:
    - name: transfer
      image: ${DEBUG_IMAGE}
      command: ["sh", "-c", "sleep 3600"]
      resources:
        requests:
          cpu: 50m
          memory: 32Mi
        limits:
          cpu: 100m
          memory: 64Mi
      volumeMounts:
        - name: host-logs
          mountPath: /host-logs
          readOnly: true
  volumes:
    - name: host-logs
      hostPath:
        path: /var/log
        type: Directory
EOF

    status "Waiting for transfer pod ${pod_name} to be ready..."
    if ! kubectl wait --for=condition=Ready "pod/${pod_name}" --timeout=120s >/dev/null 2>&1; then
        error "Transfer pod ${pod_name} failed to become ready"
        kubectl delete pod "$pod_name" --ignore-not-found >/dev/null 2>&1 || true
        return 1
    fi

    status "Copying log bundle from ${pod_name}..."
    if ! kubectl cp "${pod_name}:/host-logs/support/${node}-logs.tar.gz" "$output_path" 2>/dev/null; then
        error "Failed to copy log bundle from pod ${pod_name}"
        kubectl delete pod "$pod_name" --ignore-not-found >/dev/null 2>&1 || true
        return 1
    fi

    kubectl delete pod "$pod_name" --ignore-not-found >/dev/null 2>&1 || true
}

download_via_s3() {
    local node="$1"
    local node_index="$2"
    local s3_key="${S3_KEYS[$node_index]}"

    status "Logs for ${node} uploaded to s3://${S3_BUCKET}/${s3_key}"
}

generate_presigned_url() {
    local bucket="$1"
    local key="$2"

    python3 -c "
import boto3, sys
print(boto3.client('s3').generate_presigned_url(
    ClientMethod='put_object',
    Params={'Bucket': sys.argv[1], 'Key': sys.argv[2]},
    ExpiresIn=1000
))" "$bucket" "$key" 2>/dev/null
}

# --- Argument Parsing ---

TIMEOUT="${DEFAULT_TIMEOUT}"
OUTPUT_DIR="."
NODE_NAMES=()
TRANSFER_PODS=()
SELECTOR=""
NO_PROXY=false
DEBUG_IMAGE=""
S3_BUCKET=""
S3_KEY_PREFIX=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -l|--selector)
            [[ -z "${2:-}" ]] && { error "Flag --selector requires a value"; exit 1; }
            SELECTOR="$2"
            shift 2
            ;;
        -t|--timeout)
            [[ -z "${2:-}" ]] && { error "Flag --timeout requires a value"; exit 1; }
            TIMEOUT="$2"
            shift 2
            ;;
        -o|--output-dir)
            [[ -z "${2:-}" ]] && { error "Flag --output-dir requires a value"; exit 1; }
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --s3)
            [[ -z "${2:-}" ]] && { error "Flag --s3 requires a bucket name"; exit 1; }
            S3_BUCKET="$2"
            shift 2
            ;;
        --key)
            [[ -z "${2:-}" ]] && { error "Flag --key requires a value"; exit 1; }
            S3_KEY_PREFIX="$2"
            shift 2
            ;;
        --no-proxy)
            NO_PROXY=true
            shift
            ;;
        --debug-image)
            [[ -z "${2:-}" ]] && { error "Flag --debug-image requires a value"; exit 1; }
            DEBUG_IMAGE="$2"
            shift 2
            ;;
        -*)
            error "Unknown flag: $1"
            echo ""
            usage
            exit 1
            ;;
        *)
            NODE_NAMES+=("$1")
            shift
            ;;
    esac
done

# --- Validation ----------------------------------------------------------

if [[ -n "$SELECTOR" ]] && [[ ${#NODE_NAMES[@]} -gt 0 ]]; then
    error "Cannot combine --selector with explicit node names"
    exit 1
fi

if [[ -z "$SELECTOR" ]] && [[ ${#NODE_NAMES[@]} -eq 0 ]]; then
    error "At least one node name or --selector is required"
    echo ""
    usage
    exit 1
fi

if ! command -v kubectl &>/dev/null; then
    error "kubectl is not installed or not in PATH"
    exit 1
fi

if [[ "$OUTPUT_DIR" != "." ]] && [[ ! -d "$OUTPUT_DIR" ]]; then
    error "Output directory does not exist: ${OUTPUT_DIR}"
    exit 1
fi

if [[ -n "$S3_BUCKET" ]]; then
    if ! command -v python3 &>/dev/null; then
        error "python3 is required for --s3 flag but not found in PATH"
        exit 1
    fi
    if ! python3 -c "import boto3" 2>/dev/null; then
        error "boto3 is required for --s3 flag. Install with: pip install boto3"
        exit 1
    fi
    if [[ "$NO_PROXY" == true ]]; then
        error "Cannot use --s3 and --no-proxy together"
        exit 1
    fi
fi

if [[ -n "$S3_KEY_PREFIX" ]] && [[ -z "$S3_BUCKET" ]]; then
    error "Flag --key requires --s3 to be specified"
    exit 1
fi

if [[ "$NO_PROXY" == true ]] && [[ -z "$DEBUG_IMAGE" ]]; then
    error "Flag --debug-image is required when using --no-proxy"
    exit 1
fi

# Validate timeout format is positive integer seconds
if ! [[ "$TIMEOUT" =~ ^[0-9]+s$ ]]; then
    error "Invalid timeout format: ${TIMEOUT} (expected a positive integer followed by 's', e.g. 300s)"
    exit 1
fi

# Resolve label selector to node names
if [[ -n "$SELECTOR" ]]; then
    status "Resolving nodes matching selector: ${SELECTOR}"
    RESOLVED_NODES=()
    resolve_selector "$SELECTOR"
    NODE_NAMES=("${RESOLVED_NODES[@]}")
fi

if [[ -n "$S3_BUCKET" ]]; then
    info "Transfer mode: S3 (bucket: ${S3_BUCKET})"
elif [[ "$NO_PROXY" == true ]]; then
    info "Transfer mode: debug pod (image: ${DEBUG_IMAGE})"
else
    info "Transfer mode: node proxy API"
fi

status "Validating node(s)..."
for node in "${NODE_NAMES[@]}"; do
    if ! kubectl get node "$node" >/dev/null 2>&1; then
        error "Node not found: ${node}"
        exit 1
    fi
done
info "All ${#NODE_NAMES[@]} node(s) validated"

# --- Main ----------------------------------------------------------------

trap cleanup EXIT INT TERM

# Clean up any pre-existing NodeDiagnostic resources
for node in "${NODE_NAMES[@]}"; do
    kubectl delete nodediagnostic "$node" --ignore-not-found >/dev/null 2>&1 || true
done

# Generate pre-signed URLs if using S3
S3_KEYS=()
PRESIGNED_URLS=()
if [[ -n "$S3_BUCKET" ]]; then
    status "Generating pre-signed S3 URLs..."
    for node in "${NODE_NAMES[@]}"; do
        # Build S3 key with optional prefix
        if [[ -n "$S3_KEY_PREFIX" ]]; then
            # Remove trailing slash from prefix if present
            prefix="${S3_KEY_PREFIX%/}"
            s3_key="${prefix}/${node}-logs.tar.gz"
        else
            s3_key="${node}-logs.tar.gz"
        fi
        S3_KEYS+=("$s3_key")
        
        presigned_url=$(generate_presigned_url "$S3_BUCKET" "$s3_key")
        
        if [[ -z "$presigned_url" ]]; then
            error "Failed to generate pre-signed URL for node: ${node}"
            exit 1
        fi
        
        PRESIGNED_URLS+=("$presigned_url")
    done
    info "Generated ${#PRESIGNED_URLS[@]} pre-signed URL(s)"
fi

# Create NodeDiagnostics
status "Creating NodeDiagnostic resources..."
node_index=0
for node in "${NODE_NAMES[@]}"; do
    if [[ -n "$S3_BUCKET" ]]; then
        presigned_url="${PRESIGNED_URLS[$node_index]}"
        cat <<EOF | kubectl apply -f - >/dev/null 2>&1
apiVersion: eks.amazonaws.com/v1alpha1
kind: NodeDiagnostic
metadata:
  name: ${node}
spec:
  logCapture:
    destination: ${presigned_url}
EOF
    else
        cat <<EOF | kubectl apply -f - >/dev/null 2>&1
apiVersion: eks.amazonaws.com/v1alpha1
kind: NodeDiagnostic
metadata:
  name: ${node}
spec:
  logCapture:
    destination: node
EOF
    fi
    ((node_index++))
done

# Wait for completion and verify success
status "Waiting for log collection to complete (timeout: ${TIMEOUT})..."
for node in "${NODE_NAMES[@]}"; do
    if ! kubectl wait \
        --for='jsonpath={.status.captureStatuses[0].state.completed}' \
        "nodediagnostic/${node}" \
        --timeout="$TIMEOUT" >/dev/null 2>&1; then
        error "Timed out waiting for log collection on node: ${node}"
        for n in "${NODE_NAMES[@]}"; do
            kubectl delete nodediagnostic "$n" --ignore-not-found >/dev/null 2>&1 || true
        done
        exit 1
    fi

    # Verify completion status
    reason=$(kubectl get nodediagnostic "$node" -o jsonpath='{.status.captureStatuses[0].state.completed.reason}' 2>/dev/null)
    message=$(kubectl get nodediagnostic "$node" -o jsonpath='{.status.captureStatuses[0].state.completed.message}' 2>/dev/null)

    case "$reason" in
        Success|SuccessWithErrors)
            if [[ "$reason" == "SuccessWithErrors" ]]; then
                warn "Log collection on ${node} completed with errors: ${message}"
            fi
            ;;
        *)
            error "Log collection failed on node ${node}: reason=${reason} message=${message}"
            for n in "${NODE_NAMES[@]}"; do
                kubectl delete nodediagnostic "$n" --ignore-not-found >/dev/null 2>&1 || true
            done
            exit 1
            ;;
    esac
done
info "Log collection completed on all nodes"

# Download bundles
status "Downloading log bundles..."
node_index=0
for node in "${NODE_NAMES[@]}"; do
    if [[ -n "$S3_BUCKET" ]]; then
        download_via_s3 "$node" "$node_index"
    else
        output_path="${OUTPUT_DIR}/${node}-logs.tar.gz"
        
        if [[ "$NO_PROXY" == true ]]; then
            if ! download_via_debug_pod "$node" "$output_path"; then
                for n in "${NODE_NAMES[@]}"; do
                    kubectl delete nodediagnostic "$n" --ignore-not-found >/dev/null 2>&1 || true
                done
                exit 1
            fi
        else
            if ! download_via_proxy "$node" "$output_path"; then
                for n in "${NODE_NAMES[@]}"; do
                    kubectl delete nodediagnostic "$n" --ignore-not-found >/dev/null 2>&1 || true
                done
                exit 1
            fi
        fi

        info "Saved: ${output_path} ($(du -h "$output_path" | cut -f1))"
    fi
    ((node_index++))
done

# Cleanup NodeDiagnostic resources
for node in "${NODE_NAMES[@]}"; do
    kubectl delete nodediagnostic "$node" --ignore-not-found >/dev/null 2>&1 || true
done

echo ""
if [[ -n "$S3_BUCKET" ]]; then
    info "Done — ${#NODE_NAMES[@]} log bundle(s) uploaded to s3://${S3_BUCKET}/"
else
    info "Done — ${#NODE_NAMES[@]} log bundle(s) downloaded to ${OUTPUT_DIR}/"
fi